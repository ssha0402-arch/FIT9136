def get_letter_position(letter):
    count = 1
    alphabet = '!abcdefghijklmnopqrstuvwxyz'   
    while count <= 20:
        if alphabet[count] == letter:
            return count
        count += 1
    return 0

def get_letter(string):
    count = 0
    for letter in string:
        count += 1
    count //= 2
    i = 0
    while count >= 0:
        i += 1
        count -= 1
    return get_letter_position(string[i])
    
